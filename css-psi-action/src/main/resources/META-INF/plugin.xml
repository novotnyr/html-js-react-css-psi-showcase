<idea-plugin>
    <id>org.intellij.sdk.css-psi-action</id>
    <name>CSI PSI Action</name>
    <vendor url="https://plugins.jetbrains.com">IntelliJ Platform SDK</vendor>
    <description><![CDATA[
        Shows an action that parses a CSS file and handles its PSI.
        ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.css</depends>

    <extensions defaultExtensionNs="com.intellij">
    </extensions>
    <actions>
        <action
                id="com.intellij.sdk.cssPsi.CssPsiAction"
                class="com.intellij.sdk.cssPsi.CssPsiAction"
                text="Show CSS selectors">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
